---
import Layout from '../layouts/Layout.astro';

import mainLander1 from '../assets/projects/landerapp/main_lander-1.png';
import iconArrowNext from '../assets/next.svg';
---

<Layout title="" description="">
  <main class="details flex flex-col pt-20 pb-8 border-t-5 border-lime-500 sm:border-purple-500 md:border-blue-100 lg:border-sky-500 xl:border-red-500 2xl:border-blue-500">

    <div id="" class="container mx-auto pl-4 pr-4 mb-20">
      <h1 class="font-serif font-light mb-8">
        LanderApp<br>
        <span class="text-highlight">The power of Storytelling</span>
      </h1>
      <div class="info italic">
        <span>*</span> 
        <strong>Launched:</strong> 
        May 2014
      </div>
    </div>
    

    <div class="full-width pl-4 pr-4 mb-20 image-ml-auto">
      <img src={mainLander1.src} alt="" />
    </div>



    <div id="" class="container mx-auto pl-4 pr-4 mb-20">
      <div class="max-w-3xl">
        <p class="h4 font-serif mb-12">
          Lander is a powerful online tool that lets you create and A/B test beautiful landing pages for your online marketing campaigns using an easy step-by-step process.
        </p>

        <h2 class="h1 font-serif font-light mb-8">
          My role: the goals
        </h2>
        <div class="info italic mb-10">
          <span>*</span> 
          <strong>Responsibilities:</strong> 
          Research, Branding, Illustrations.
        </div>

        <p class="mb-10">
          As a designer tasked with creating the illustration style for Landerapp's rebrand and new website, my goal was to create visuals that would both impact and resonate with our target audience. 
        </p>
        <p class="h3 font-serif font-light">
          I started crafting an empathy map to understand their needs, emotions, and behaviors in order to create illustrations tailored to the users' insights, making the website more engaging, relatable, and user-friendly.
        </p>
      </div>
    </div>









    <!-- Next case study -->
    <div id="" class="container mx-auto text-center pl-4 pr-4">
      <div class="flex justify-end">
        <a href="/fromdoppler-unlocking-automation-for-everyone" class="flex items-center gap-4 justify-end font-bold underline hover:no-underline">
        <img src={iconArrowNext.src} alt="Next case study" class="" width="48px" />
        </a>
      </div>
    </div>

  </main>
</Layout>

<style>
</style>


<script>
  const imageMlAuto: NodeListOf<HTMLImageElement> | null = document.querySelectorAll('.image-ml-auto img').length > 0
    ? document.querySelectorAll('.image-ml-auto img') as NodeListOf<HTMLImageElement>
    : null;
  const container = document.querySelector('.container');
  let marginLeft = '0px';
  if (container) marginLeft = window.getComputedStyle(container).marginLeft;

    function setImagesMarginLeft(images: NodeListOf<HTMLImageElement> | null, marginLeft: string): void {
      if (!images) return;
      const ml = parseFloat(marginLeft) || 0;
      images.forEach((img: HTMLImageElement) => {
        img.style.marginLeft = `${ml}px`;
        img.style.width = `${Math.max(0, img.width - ml + 16)}px`;
      });
    }

    setImagesMarginLeft(imageMlAuto, marginLeft);

    window.addEventListener('resize', () => {
      if (container) marginLeft = window.getComputedStyle(container).marginLeft;
      setImagesMarginLeft(imageMlAuto, marginLeft);
    });
</script>